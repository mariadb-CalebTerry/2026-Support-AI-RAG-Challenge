# Database Configuration (Required)
DB_HOST=rag-mariadb
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_NAME=support_ai_rag_db

# Authentication (Required)
SECRET_KEY=your_secret_key_here

# Embedding Configuration (Required)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.0-flash
EMBEDDING_PROVIDER=gemini
embedding_model=text-embedding-004

# API Keys (Set based on your embedding/LLM provider)
GEMINI_API_KEY=your_gemini_api_key_here

MARIADB_LICENSE_KEY=your_mariadb_license_key_here

# Service Configuration (Docker environment)
APP_HOST=rag-api
MCP_HOST=rag-api
MCP_MARIADB_HOST=rag-api
DOCLING_RAY_SERVICE_URL=http://rag-docling-ray:8003
CELERY_BROKER_URL=redis://rag-redis:6379/0

# RAG Table Configuration (Required for Single Vector Store Strategy)
DOCUMENTS_TABLE=zendesk_documents
VDB_TABLE=zendesk_vectors

# Additional Security Keys (`openssl rand -hex 32`)
JWT_SECRET_KEY=your_jwt_secret_key_here
MCP_AUTH_SECRET_KEY=your_mcp_auth_secret_key_here